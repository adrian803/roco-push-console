# 可选：作为首次启动默认值；之后可在 Web 控制台修改
ROCOM_API_KEY=

# 可选：自定义 WeGame 数据接口；通常保持空即可
ROCOM_API_URL=

# 可选：作为首次启动默认值；之后可在 Web 控制台修改
SERVERCHAN_SENDKEY=

# 可选：没有商品时是否也推送
NOTIFY_EMPTY=false

# 可选：首次启动默认发送策略 all / single / failover
DELIVERY_MODE=all

# 可选：HTTP 超时秒数
HTTP_TIMEOUT=30

# Docker 常驻调度使用：北京时间执行时间，逗号分隔
SCHEDULE_TIMES=08:01,12:01,16:01,20:01

# Docker 常驻调度使用：容器启动后是否立即执行一次
RUN_ON_START=false

# Web 控制台
WEB_PORT=19892
DOCKER_IMAGE=linxi5013/roco-push-console:latest
CONSOLE_USERNAME=admin
CONSOLE_PASSWORD=
